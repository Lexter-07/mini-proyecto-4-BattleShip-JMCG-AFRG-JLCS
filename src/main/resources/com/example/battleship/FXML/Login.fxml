<?xml version="1.0" encoding="UTF-8"?>

<?import com.example.battleship.view.fx.GameButton?>
<?import com.example.battleship.view.fx.OceanCanvas?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="650.0" prefWidth="900.0" stylesheets="@../CSS/theme.css,@../CSS/login.css"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.battleship.controller.LoginController">
    <children>

        <!-- Fondo del océano animado -->
        <OceanCanvas/>

        <BorderPane pickOnBounds="false">

            <top>
                <VBox alignment="CENTER" spacing="8" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets top="46"/>
                    </padding>
                    <Label styleClass="menu-eyebrow" text="BATTLESHIP"/>
                    <Label styleClass="title" text="INGRESO DE COMANDANTE"/>
                </VBox>
            </top>

            <center>
                <StackPane>
                    <VBox alignment="CENTER" maxHeight="280.0" maxWidth="400.0" spacing="25" styleClass="glass-panel-strong">
                        <padding>
                            <Insets bottom="34" left="34" right="34" top="34"/>
                        </padding>

                        <Label styleClass="subtitle" text="Identifícate para comandar tu flota"/>

                        <VBox alignment="CENTER" spacing="10">
                            <Label styleClass="input-label" text="NOMBRE DEL COMANDANTE" />
                            <TextField fx:id="nicknameField" alignment="CENTER" promptText="Ej. Almirante Nelson" styleClass="custom-text-field" />
                        </VBox>

                        <!-- Único botón apuntando al método correcto -->
                        <GameButton fx:id="enterButton" maxWidth="Infinity" onAction="#onHandleEnter" text="INGRESAR AL MENÚ"/>
                    </VBox>
                </StackPane>
            </center>

            <bottom>
                <HBox alignment="BOTTOM_CENTER" prefHeight="59.0" spacing="10" styleClass="menu-footer">
                    <padding>
                        <Insets bottom="20"/>
                    </padding>
                    <Label styleClass="hud-label" text="Comando Naval"/>
                    <Label styleClass="hud-label" text="•"/>
                    <Label styleClass="hud-label" text="Preparación de Flota"/>
                </HBox>
            </bottom>

        </BorderPane>

    </children>
</StackPane>