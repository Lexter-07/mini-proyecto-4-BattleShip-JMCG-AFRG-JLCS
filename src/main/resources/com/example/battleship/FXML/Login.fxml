<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="25.0" style="-fx-background-color: #1e272e;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.battleship.controller.LoginController">
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
    </padding>

    <!-- Title -->
    <Label text="BATTLESHIP" textFill="#0ae4fc">
        <font>
            <Font name="System Bold" size="48.0" />
        </font>
    </Label>

    <Label text="Enter your nickname to command your fleet" textFill="#d2dae2">
        <font>
            <Font size="16.0" />
        </font>
    </Label>

    <!-- Input Area -->
    <VBox alignment="CENTER" maxWidth="300.0" spacing="10.0" style="-fx-background-color: #485460; -fx-background-radius: 5;">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
        <Label text="COMMANDER NAME" textFill="WHITE">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
        <TextField fx:id="nicknameField" alignment="CENTER" promptText="e.g. Admiral Nelson" style="-fx-background-color: #d2dae2; -fx-background-radius: 3; -fx-font-size: 14px;" />
    </VBox>

    <!-- Action Buttons -->
    <HBox alignment="CENTER" spacing="20.0">
        <Button mnemonicParsing="false" onAction="#onHandleNewGame" style="-fx-background-color: #0fb9b1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 5;" text="NEW GAME" />
        <Button mnemonicParsing="false" onAction="#onHandleContinue" style="-fx-background-color: #f7b731; -fx-text-fill: #1e272e; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 5;" text="CONTINUE GAME" />
    </HBox>
</VBox>