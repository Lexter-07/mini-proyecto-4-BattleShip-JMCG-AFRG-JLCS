<?xml version="1.0" encoding="UTF-8"?>

<?import com.example.battleship.view.fx.GameButton?>
<?import com.example.battleship.view.fx.OceanCanvas?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="650.0" prefWidth="900.0" stylesheets="@../CSS/theme.css,@../CSS/menu.css"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.battleship.controller.MenuController">
    <children>

        <!-- Animated ocean, fog and fills the whole window behind everything else. -->
        <OceanCanvas/>

        <BorderPane pickOnBounds="false">

            <top>
                <VBox alignment="CENTER" spacing="8" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets top="46"/>
                    </padding>
                    <Label styleClass="menu-eyebrow" text="COMANDO NAVAL"/>
                    <Label styleClass="title" text="⚓ BATALLA NAVAL"/>
                    <Label styleClass="subtitle" text="Domina los océanos"/>
                </VBox>
            </top>

            <center>
                <StackPane>
                    <VBox alignment="CENTER" maxHeight="320.0" maxWidth="360" minHeight="220.0"
                          prefWidth="360.0" spacing="18" styleClass="glass-panel-strong">
                        <padding>
                            <Insets bottom="34" left="34" right="34" top="34"/>
                        </padding>

                        <GameButton fx:id="newGameButton" maxWidth="Infinity" onAction="#onHandleNewGame"
                                    text="NUEVA PARTIDA"/>

                        <GameButton fx:id="continueButton" maxWidth="Infinity" onAction="#onHandleContinue"
                                    text="CONTINUAR"/>

                        <GameButton fx:id="exitButton" maxWidth="Infinity" onAction="#onHandleExit"
                                    styleClass="danger-button" text="SALIR"/>
                    </VBox>
                </StackPane>
            </center>

            <bottom>
                <HBox alignment="BOTTOM_CENTER" prefHeight="59.0" spacing="10" styleClass="menu-footer">
                    <padding>
                        <Insets bottom="20"/>
                    </padding>
                    <Label styleClass="hud-label" text="Universidad del Valle"/>
                    <Label styleClass="hud-label" text="•"/>
                    <Label styleClass="hud-label" text="POE 2026-II"/>
                </HBox>
            </bottom>

        </BorderPane>

    </children>
</StackPane>